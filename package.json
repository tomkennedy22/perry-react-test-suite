{
  "name": "my-app",
  "version": "1.0.0",
  "description": "Representative real-world Electron app running on Perry",
  "main": "src/main.ts",
  "license": "MIT",
  "dependencies": {
    "@perryts/perry": "^0.5.1182",
    "electron": "file:../../../../private/tmp/perry-electron-compat/packages/electron"
  },
  "scripts": {
    "dev:backend": "PERRY_DEV=1 ./system-explorer",
    "dev:renderer": "vite",
    "build": "vite build && /tmp/perry-electron-compat/target/release/perry compile src/main.ts -o system-explorer",
    "start": "npm run build && ./system-explorer"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  }
}
